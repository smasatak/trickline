# Copy to .env and adjust. Defaults match docker-compose (Postgres + MinIO).

DATABASE_URL=postgresql+asyncpg://trickline:trickline@localhost:5432/trickline

# S3-compatible object storage.
# Local: MinIO (docker-compose). Production: Cloudflare R2.
#   R2 example endpoint: https://<accountid>.r2.cloudflarestorage.com
# Switching MinIO -> R2 only requires changing these env vars; see
# backend/README.md "Switching to Cloudflare R2" for the step-by-step setup.
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=trickline-videos
# Public base URL used to build playback URLs (MinIO anonymous download).
# For R2 this would be your public bucket / custom domain (or the r2.dev
# subdomain while testing).
S3_PUBLIC_BASE_URL=http://localhost:9000/trickline-videos
# Path-style addressing (http://endpoint/bucket/key). Works for both MinIO
# and R2; leave as true unless you have a specific reason to use
# virtual-hosted-style URLs.
S3_USE_PATH_STYLE=true

# Auth
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Uploads
MAX_VIDEO_SECONDS=60
ALLOWED_CONTENT_TYPES=video/mp4,video/quicktime

CORS_ORIGINS=http://localhost:5173
